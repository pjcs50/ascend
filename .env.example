# Ascend — Supabase credentials
# Copy this file to .env.local and fill in the values from your Supabase project:
#   Supabase Dashboard → Project Settings → API
# These are read by Vite at build time (any VITE_-prefixed var is exposed to the client).
# The anon key is safe in the client; privacy is enforced by Row-Level Security.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
